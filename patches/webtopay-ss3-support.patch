@@ -1,11 +1,25 @@
 <?php
 
 /**
- * Checks SS2 signature. Depends on SSL functions
+ * Checks SS2/SS3 signature. Depends on SSL functions
+ *
+ * SS3 (SHA-256) is preferred over SS2 (SHA-1) when both are present, since SHA-1
+ * signature verification is rejected under OpenSSL 3.x's default security policy.
  */
 class WebToPay_Sign_SS2SignChecker implements WebToPay_Sign_SignCheckerInterface {
 
     /**
+     * Maps supported signature request parameters to their OpenSSL digest algorithm,
+     * ordered from lowest to highest preference
+     *
+     * @var array
+     */
+    const SIGN_ALGORITHM_MAP = array(
+        'ss2' => OPENSSL_ALGO_SHA1,
+        'ss3' => OPENSSL_ALGO_SHA256,
+    );
+
+    /**
      * @var string
      */
     protected $publicKey;
@@ -36,12 +50,15 @@
      * @throws WebToPay_Exception_Callback
      */
     public function checkSign(array $request) {
-        if (!isset($request['data']) || !isset($request['ss2'])) {
+        $signParams = array_intersect(array_keys(self::SIGN_ALGORITHM_MAP), array_keys($request));
+        $signParam = end($signParams);
+
+        if (!isset($request['data']) || $signParam === false) {
             throw new WebToPay_Exception_Callback('Not enough parameters in callback. Possible version mismatch');
         }
 
-        $ss2 = $this->util->decodeSafeUrlBase64($request['ss2']);
-        $ok = openssl_verify($request['data'], $ss2, $this->publicKey);
+        $sign = $this->util->decodeSafeUrlBase64($request[$signParam]);
+        $ok = openssl_verify($request['data'], $sign, $this->publicKey, self::SIGN_ALGORITHM_MAP[$signParam]);
         return $ok === 1;
     }
 }
